{
  "name": "llm-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "fmt": "oxfmt .",
    "lint": "oxfmt --check . && eslint .",
    "deploy": "npm run build && echo 'Static files ready in build/ directory'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.2.2",
    "eslint": "^10.2.1",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.5.0",
    "oxfmt": "^0.45.0",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/genai": "^1.50.1",
    "bits-ui": "^2.18.0",
    "dompurify": "^3.4.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.2",
    "marked-highlight": "^2.2.4",
    "openai": "^6.34.0",
    "temml": "^0.13.2"
  },
  "patchedDependencies": {
    "temml@0.13.2": "patches/temml@0.13.2.patch"
  }
}
